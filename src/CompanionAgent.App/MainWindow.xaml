<Window x:Class="CompanionAgent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sim Racing Companion"
        Height="580" Width="780"
        MinHeight="500" MinWidth="660"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SIM RACING COMPANION"
                           FontWeight="Bold" FontSize="14" FontFamily="Consolas"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource ErrorBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Desconectado"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control with icon symbols in headers -->
        <TabControl Grid.Row="1" x:Name="MainTabs"
                    Background="{StaticResource BgBrush}"
                    BorderThickness="0">
            <TabItem x:Name="TabOverview">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊙" Margin="0,0,5,0" FontSize="13"/>
                        <TextBlock Text="Visão Geral"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="OverviewContent"/>
            </TabItem>
            <TabItem x:Name="TabLog">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="≡" Margin="0,0,5,0" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Log"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="LogContent"/>
            </TabItem>
            <TabItem x:Name="TabSettings">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" Margin="0,0,5,0" FontSize="13"/>
                        <TextBlock Text="Configurações"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="SettingsContent"/>
            </TabItem>
            <TabItem x:Name="TabAbout">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ" Margin="0,0,5,0" FontSize="13"/>
                        <TextBlock Text="Sobre"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="AboutContent"/>
            </TabItem>
        </TabControl>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="SyncDot" Grid.Column="0"
                         Width="7" Height="7"
                         Fill="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                <TextBlock x:Name="SyncStateText" Grid.Column="1"
                           Text="Pronto"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="v3.0.0"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
