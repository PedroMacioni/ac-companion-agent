<Window x:Class="CompanionAgent.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sim Racing Companion"
        Height="560" Width="760"
        MinHeight="480" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SIM RACING COMPANION"
                           FontWeight="Bold" FontSize="14" FontFamily="Consolas"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource ErrorBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Desconectado"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" x:Name="MainTabs"
                    Background="{StaticResource BgBrush}"
                    BorderThickness="0">
            <TabItem Header="Visão Geral" x:Name="TabOverview">
                <ContentControl x:Name="OverviewContent"/>
            </TabItem>
            <TabItem Header="Log" x:Name="TabLog">
                <ContentControl x:Name="LogContent"/>
            </TabItem>
            <TabItem Header="Configurações" x:Name="TabSettings">
                <ContentControl x:Name="SettingsContent"/>
            </TabItem>
            <TabItem Header="Sobre" x:Name="TabAbout">
                <ContentControl x:Name="AboutContent"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
