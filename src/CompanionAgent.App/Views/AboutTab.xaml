<UserControl x:Class="CompanionAgent.App.Views.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="480" HorizontalAlignment="Left">

            <!-- App info -->
            <TextBlock Text="SIM RACING COMPANION" FontSize="18" FontWeight="Bold"
                       FontFamily="Consolas" Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="VersionText" Text="Versão 3.0.0"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                       Margin="0,0,0,24"/>

            <!-- Update section -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ATUALIZAÇÃO" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="UpdateStatusText" Text="Verificando atualizações..."
                               Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>

                    <!-- Update available banner -->
                    <Border x:Name="UpdateBanner" Visibility="Collapsed"
                            Background="{StaticResource BgBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12,10" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock x:Name="UpdateVersionText"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnInstallUpdate"
                                        Style="{StaticResource AccentButton}"
                                        Content="Instalar e reiniciar"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="BtnViewChangelog"
                                        Content="Ver novidades"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,14">
                <StackPanel>
                    <Button x:Name="BtnGitHub" Content="Ver no GitHub"
                            HorizontalAlignment="Left" Padding="12,6"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
