<UserControl x:Class="CompanionAgent.App.Views.LogTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Filtro:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                <ComboBox Grid.Column="1" x:Name="FilterCombo" Width="110" FontSize="12">
                    <ComboBoxItem Content="Todos" Tag=""/>
                    <ComboBoxItem Content="Info" Tag="Info"/>
                    <ComboBoxItem Content="Avisos" Tag="Warning"/>
                    <ComboBoxItem Content="Erros" Tag="Error"/>
                </ComboBox>
                <Button Grid.Column="3" x:Name="BtnClear" Content="Limpar"
                        FontSize="12" Margin="0,0,6,0"/>
                <Button Grid.Column="4" x:Name="BtnOpenFile" Content="Abrir arquivo"
                        FontSize="12"/>
            </Grid>
        </Border>

        <!-- Log list -->
        <ListBox Grid.Row="1" x:Name="LogList"
                 Background="{StaticResource BgBrush}"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 FontFamily="Consolas" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding TimestampText}"
                                   Foreground="{Binding TimestampColor}" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding LevelText}"
                                   Foreground="{Binding LevelColor}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{Binding CategoryText}"
                                   Foreground="{Binding TimestampColor}" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="{Binding Message}"
                                   Foreground="{Binding LevelColor}" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
