<UserControl x:Class="CompanionAgent.App.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="560" HorizontalAlignment="Left">

            <!-- Account section -->
            <TextBlock Text="CONTA" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Logged in view -->
                    <StackPanel x:Name="PanelLoggedIn">
                        <TextBlock x:Name="TxtLoggedAs" Text="Conectado como —"
                                   FontSize="13" Margin="0,0,0,8"/>
                        <Button x:Name="BtnLogout" Content="Desconectar"
                                HorizontalAlignment="Left" Padding="12,6"/>
                    </StackPanel>

                    <!-- Login options -->
                    <StackPanel x:Name="PanelLogin" Visibility="Collapsed">

                        <!-- Primary: device auth -->
                        <Button x:Name="BtnConnectViaWeb"
                                Content="⊙  Conectar via site (recomendado)"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch"
                                Padding="0,12"
                                FontSize="14"
                                Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtDeviceAuthStatus" Text=""
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Margin="0,0,0,12" Visibility="Collapsed"/>
                        <Button x:Name="BtnCancelDeviceAuth" Content="Cancelar"
                                HorizontalAlignment="Left" FontSize="12"
                                Visibility="Collapsed" Margin="0,0,0,12"/>

                        <Separator/>

                        <!-- Secondary: email/password -->
                        <CheckBox x:Name="ChkEmailLogin"
                                  Content="Entrar com e-mail"
                                  Foreground="{StaticResource TextMutedBrush}"
                                  FontSize="12" Margin="0,8,0,8"/>

                        <StackPanel x:Name="PanelEmailLogin" Visibility="Collapsed">
                            <TextBlock Text="E-mail" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtEmail" Margin="0,0,0,10" Width="280" HorizontalAlignment="Left"/>

                            <TextBlock Text="Senha" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtPassword" Margin="0,0,0,10" Width="280" HorizontalAlignment="Left"/>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnLogin" Content="Entrar"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,0,8,0" Padding="16,6"/>
                                <TextBlock x:Name="TxtLoginError" Text=""
                                           Foreground="{StaticResource ErrorBrush}"
                                           VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Paths section -->
            <TextBlock Text="PASTAS" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>

                    <!-- AC Path -->
                    <TextBlock Text="Pasta do Assetto Corsa" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtAcPath" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" x:Name="BtnDetectAc" Content="Detectar"
                                FontSize="12" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" x:Name="BtnBrowseAc" Content="..."
                                Width="32" FontSize="12"/>
                    </Grid>

                    <!-- CM Sessions Path -->
                    <TextBlock Text="Pasta de sessões do Content Manager" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtCmPath" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" x:Name="BtnDetectCm" Content="Detectar"
                                FontSize="12" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" x:Name="BtnBrowseCm" Content="..."
                                Width="32" FontSize="12"/>
                    </Grid>

                    <!-- PB Path -->
                    <TextBlock Text="Arquivo personalbest.ini" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtPbPath" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" x:Name="BtnBrowsePb" Content="..."
                                Width="32" FontSize="12"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Agent section -->
            <TextBlock Text="AGENTE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Mode -->
                    <TextBlock Text="Modo" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ComboMode" Margin="0,0,0,12" HorizontalAlignment="Left" Width="200">
                        <ComboBoxItem Content="Fonte de dados" Tag="source"/>
                        <ComboBoxItem Content="Somente visualização" Tag="viewer"/>
                    </ComboBox>

                    <!-- Language -->
                    <TextBlock Text="Idioma" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <ComboBox x:Name="ComboLang" HorizontalAlignment="Left" Width="200" Margin="0,0,10,0">
                            <ComboBoxItem Content="Português (BR)" Tag="pt-BR"/>
                            <ComboBoxItem Content="English" Tag="en"/>
                        </ComboBox>
                        <TextBlock x:Name="LangRestartHint" Text="(requer reinício)"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="11" Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,8"/>

                    <!-- Auto-start -->
                    <CheckBox x:Name="ChkAutoStart" Content="Iniciar com o Windows"
                              Margin="0,0,0,12"/>

                    <!-- Poll interval -->
                    <TextBlock Text="Verificação web (segundos)" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="SliderPoll" Minimum="10" Maximum="120" Width="200"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtPollValue" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Save button -->
            <Button x:Name="BtnSave" Content="Salvar configurações"
                    Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" Padding="16,8"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
